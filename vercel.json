{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/(auth|teams|tasks|messages|health|docs|openapi.json|redoc)(/.*)?$", "dest": "api/index.py" },
    { "src": "^/(.*)$", "dest": "/frontend/$1" }
  ]
}
